<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<gpx xmlns="http://www.topografix.com/GPX/1/1" version="1.1" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.topografix.com/GPX/1/1 http://www.topografix.com/GPX/1/1/gpx.xsd" creator="Cirkwi"><metadata><name><![CDATA[Boucle vélo: Les premiers Grands Crus Classés]]></name><desc><![CDATA[Cette boucle de 15 km au profil assez plat s’adresse à tous les passionnés du vin qui souhaitent apercevoir de prestigieuses propriétés viticoles de Saint-Emilion. Le parcours serpente entre les vignes de ces Châteaux de renom situés sur le fameux plateau calcaire autour du village.]]></desc><author><name><![CDATA[Office de Tourisme du Grand Saint-Emilionnais]]></name></author><link href="http://fichier0.cirkwi.com/image/photo/circuit/1300x1300/61927/fr/0.jpg"></link><link href="http://fichier0.cirkwi.com/image/photo/circuit/1300x1300/61927/fr/1.jpg"></link><link href="http://fichier0.cirkwi.com/image/photo/circuit/1300x1300/61927/fr/2.jpg"></link><link href="http://fichier0.cirkwi.com/image/photo/circuit/1300x1300/61927/fr/3.jpg"></link><link href="http://fichier0.cirkwi.com/image/photo/circuit/1300x1300/61927/fr/4.jpg"></link><time>2024-07-07T00:27:59Z</time></metadata><wpt lat="44.893591" lon="-0.156818"><name><![CDATA[Etape 1]]></name><desc><![CDATA[A l’angle de l’Office de Tourisme et de la Maison du Vin, prenez la rue des anciennes écoles.]]></desc></wpt><wpt lat="44.892614" lon="-0.158063"><name><![CDATA[Etape 2]]></name><desc><![CDATA[Au bout de la rue des écoles, laissez la Porte St-Martin sur votre droite et tournez à gauche dans la rue du Couvent.]]></desc></wpt><wpt lat="44.891999" lon="-0.15736"><name><![CDATA[Etape 3]]></name><desc><![CDATA[Passez derrière la Tour du Roy et continuez tout droit.]]></desc></wpt><wpt lat="44.890399" lon="-0.156625"><name><![CDATA[Etape 4]]></name><desc><![CDATA[Passez l’ancienne Porte Sainte- Marie et dans la rue des douves face aux carrières, tournez à gauche pour prendre la ruelle « Porte Sainte-Marie ».]]></desc></wpt><wpt lat="44.889916" lon="-0.156217"><name><![CDATA[Etape 5]]></name><desc><![CDATA[Au bout de la ruelle, remontez la rue de la Madeleine à droite.]]></desc></wpt><wpt lat="44.88946" lon="-0.156233"><name><![CDATA[Etape 6]]></name><desc><![CDATA[Passez devant le Ch. Ausone et continuez à monter le sentier.]]></desc></wpt><wpt lat="44.888282" lon="-0.159538"><name><![CDATA[Etape 7]]></name><desc><![CDATA[Au Clos La Madeleine, continuez jusqu’au stop au niveau du Ch. Belair-Monange.]]></desc></wpt><wpt lat="44.888837" lon="-0.16178"><name><![CDATA[Etape 8]]></name><desc><![CDATA[Au stop, continuez tout droit direction Ch. Canon.]]></desc></wpt><wpt lat="44.889148" lon="-0.163218"><name><![CDATA[Etape 9]]></name><desc><![CDATA[Face à la croix, suivez la rue principale à droite.]]></desc></wpt><wpt lat="44.89187" lon="-0.1642"><name><![CDATA[Etape 10]]></name><desc><![CDATA[Au stop, en bas de la descente, tournez à gauche en direction du Ch. Angélus.]]></desc></wpt><wpt lat="44.893101" lon="-0.170916"><name><![CDATA[Etape 11]]></name><desc><![CDATA[Passez devant Ch. Angélus et Ch. Coutet. Descendez sur 1 km.]]></desc></wpt><wpt lat="44.896719" lon="-0.181468"><name><![CDATA[Etape 12]]></name><desc><![CDATA[Au hameau, tournez à droite vers Ch. Arnaud de Jacquemeau.]]></desc></wpt><wpt lat="44.900929" lon="-0.179569"><name><![CDATA[Etape 13]]></name><desc><![CDATA[À l'intersection, à hauteur du Ch. Granc Mayne, tournez à droite en direction du Ch. Laroze. Passez devant la propriété et continuez tout droit jusqu’au stop.]]></desc></wpt><wpt lat="44.905568" lon="-0.173056"><name><![CDATA[Etape 14]]></name><desc><![CDATA[Au stop situé au croisement avec la D243, tournez à droite et immédiatement à gauche en direction de Ch. La Fleur Picon.]]></desc></wpt><wpt lat="44.905998" lon="-0.171388"><name><![CDATA[Etape 15]]></name><desc><![CDATA[Prenez la 1ère à gauche, en direction du Ch. Bezineau.]]></desc></wpt><wpt lat="44.910618" lon="-0.17488"><name><![CDATA[Etape 16]]></name><desc><![CDATA[A la patte d’oie, prenez en face en laissant le Ch. Bezineau sur votre droite.]]></desc></wpt><wpt lat="44.914021" lon="-0.181189"><name><![CDATA[Etape 17]]></name><desc><![CDATA[Traversez le lieu-dit Fortin en passant devant le Ch. Monlabert (sur la gauche).]]></desc></wpt><wpt lat="44.915739" lon="-0.180491"><name><![CDATA[Etape 18]]></name><desc><![CDATA[Au carrefour, laissez le Ch. Ripeau sur votre droite et tournez à gauche. Longez ainsi les vignes notamment celles du Ch. La Dominique (restaurant La Terrasse Rouge) sur la droite.]]></desc></wpt><wpt lat="44.915564" lon="-0.189267"><name><![CDATA[Etape 19]]></name><desc><![CDATA[Au stop, tournez à droite sur la D245 et passez devant Ch. Cheval Blanc et le Ch. Tour du Pin Figeac.]]></desc></wpt><wpt lat="44.923244" lon="-0.197153"><name><![CDATA[Etape 20]]></name><desc><![CDATA[Au stop sur la D244, continuez en face pour aller vers Pomerol.]]></desc></wpt><wpt lat="44.926838" lon="-0.19888"><name><![CDATA[Etape 21]]></name><desc><![CDATA[Au stop sur la D121 au niveau du Ch. Certan, tournez à droite en direction de Néac et Lussac.]]></desc></wpt><wpt lat="44.930795" lon="-0.192593"><name><![CDATA[Etape 22]]></name><desc><![CDATA[Passez devant le Ch. Pétrus puis continuez tout droit sur la route principale.]]></desc></wpt><wpt lat="44.931277" lon="-0.190453"><name><![CDATA[Etape 23]]></name><desc><![CDATA[Tournez à droite après Pétrus pour suivre le chemin de Chantecaille en direction de Maillet.]]></desc></wpt><wpt lat="44.9289" lon="-0.184831"><name><![CDATA[Etape 24]]></name><desc><![CDATA[Au cédez-le-passage, continuez tout droit en passant devant le Ch. La Croix-Chantecaille.]]></desc></wpt><wpt lat="44.923913" lon="-0.179097"><name><![CDATA[Etape 25]]></name><desc><![CDATA[Au stop, tournez à gauche sur la D244 en direction du Ch. Corbin.]]></desc></wpt><wpt lat="44.924475" lon="-0.170208"><name><![CDATA[Etape 26]]></name><desc><![CDATA[Passez devant le Ch. Grand Corbin d’Espagne et le Ch. Corbin pour descendre et prendre la route à droite en direction du Ch. Grand Corbin Manuel.]]></desc></wpt><wpt lat="44.920608" lon="-0.171919"><name><![CDATA[Etape 27]]></name><desc><![CDATA[Au croisement, tournez à la 1ère à gauche et passez devant le Ch. Grand Corbin.]]></desc></wpt><wpt lat="44.91888" lon="-0.166962"><name><![CDATA[Etape 28]]></name><desc><![CDATA[A l’intersection, passez devant les Ch. Jean Voisin (sur la gauche) et le Ch. Chauvin (sur la droite) puis continuez tout droit.]]></desc></wpt><wpt lat="44.911225" lon="-0.164253"><name><![CDATA[Etape 29]]></name><desc><![CDATA[Au prochain croisement, tournez à gauche vers le Ch. de Rol.]]></desc></wpt><wpt lat="44.908631" lon="-0.154544"><name><![CDATA[Etape 30]]></name><desc><![CDATA[A l’intersection, face au panneau STVE, prenez à droite et roulez en direction du Ch. Moulin du Cadet.]]></desc></wpt><trk><trkseg><trkpt lat="44.89359" lon="-0.15689"><ele>81.05</ele></trkpt><trkpt lat="44.89357" lon="-0.1569"><ele>81</ele></trkpt><trkpt lat="44.89356" lon="-0.15691"><ele>80.98</ele></trkpt><trkpt lat="44.89354" lon="-0.15692"><ele>80.98</ele></trkpt><trkpt lat="44.89353" lon="-0.15693"><ele>80.98</ele></trkpt><trkpt lat="44.89348" lon="-0.15698"><ele>80.73</ele></trkpt><trkpt lat="44.89344" lon="-0.15703"><ele>80.8</ele></trkpt><trkpt lat="44.89339" lon="-0.1571"><ele>80.5</ele></trkpt><trkpt lat="44.89314" lon="-0.15747"><ele>79.48</ele></trkpt><trkpt lat="44.89311" lon="-0.15753"><ele>79.06</ele></trkpt><trkpt lat="44.89308" lon="-0.1576"><ele>77.87</ele></trkpt><trkpt lat="44.89305" lon="-0.15765"><ele>77.41</ele></trkpt><trkpt lat="44.89302" lon="-0.1577"><ele>77.11</ele></trkpt><trkpt lat="44.89299" lon="-0.15775"><ele>76.88</ele></trkpt><trkpt lat="44.89296" lon="-0.15778"><ele>76.75</ele></trkpt><trkpt lat="44.89293" lon="-0.15782"><ele>76.69</ele></trkpt><trkpt lat="44.8929" lon="-0.15785"><ele>76.77</ele></trkpt><trkpt lat="44.89285" lon="-0.1579"><ele>76.98</ele></trkpt><trkpt 