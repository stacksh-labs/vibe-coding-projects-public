<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<gpx xmlns="http://www.topografix.com/GPX/1/1" version="1.1" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.topografix.com/GPX/1/1 http://www.topografix.com/GPX/1/1/gpx.xsd" creator="Cirkwi"><metadata><name><![CDATA[Les architectures remarquables]]></name><desc><![CDATA[Partez à la découverte du vignoble et du patrimoine St-Emilionnais. Sur ce parcours de 19 km, légèrement vallonné, vous admirerez de multiples châteaux et églises à l’architecture remarquable et profiterez de beaux points de vue sur la Juridiction de St-Emilion.]]></desc><author><name><![CDATA[Office de Tourisme du Grand Saint-Emilionnais]]></name></author><link href="http://fichier0.cirkwi.com/image/photo/circuit/1300x1300/36759/fr/0.jpg"></link></metadata><wpt lat="44.8937507" lon="-0.1569736"><name></name><desc><![CDATA[Depuis l’Office de Tourisme, passez devant la Maison du Vin et l’église, puis tournez à droite.]]></desc></wpt><wpt lat="44.8958902" lon="-0.1555574"><name></name><desc><![CDATA[Au rond-point, continuez tout droit direction St-Christophe.]]></desc></wpt><wpt lat="44.8967414" lon="-0.1526713"><name></name><desc><![CDATA[Suivez les premières indications « Saint-Emilion Sud » en tournant à droite sur la D243E1. Passez devant le Ch. La Couspaude (sur votre gauche).]]></desc></wpt><wpt lat="44.8951986" lon="-0.1465452"><name></name><desc><![CDATA[Laissez « Saint-Emilion Sud » à droite et continuez sur la D243 en restant à droite à la patte-d’oie. Longez ainsi le Ch. Trottevieille.]]></desc></wpt><wpt lat="44.896027" lon="-0.1420069"><name></name><desc><![CDATA[Au panneau « Haut-Sarpe », tournez à gauche. Passez devant le moulin et traversez le Ch. Haut-Sarpe.]]></desc></wpt><wpt lat="44.8959966" lon="-0.1373935"><name></name><desc><![CDATA[Tournez à droite pour revenir sur la D243, puis à gauche, au niveau du Cédez-le-passage vers St-Christophe. Passez devant Ch. des Laudes et Ch. Panet. Dans le village, allez jusqu’au rond-point.]]></desc></wpt><wpt lat="44.8959586" lon="-0.1241755"><name></name><desc><![CDATA[Juste avant le rond-point de St-Christophe, tournez en épingle à droite vers la Mairie.]]></desc></wpt><wpt lat="44.8922344" lon="-0.1263911"><name></name><desc><![CDATA[Continuez tout droit jusqu’au carrefour au niveau du Ch. Lapelletrie. Tournez à gauche en direction du Ch. Laroque.]]></desc></wpt><wpt lat="44.8913755" lon="-0.1183605"><name></name><desc><![CDATA[Passez devant le Ch. Laroque, puis continuez tout droit jusqu'au stop.]]></desc></wpt><wpt lat="44.8898249" lon="-0.1131034"><name></name><desc><![CDATA[Au stop, tournez à droite sur la D243E2.]]></desc></wpt><wpt lat="44.8871265" lon="-0.1141441"><name></name><desc><![CDATA[Dans la descente, tournez à gauche vers l’église de St-Hippolyte.]]></desc></wpt><wpt lat="44.8868909" lon="-0.1141441"><name></name><desc><![CDATA[Tournez tout de suite à droite en direction du Ch. de Ferrand. Continuez tout droit jusqu’aux prochaines maisons.]]></desc></wpt><wpt lat="44.8835461" lon="-0.1180816"><name></name><desc><![CDATA[Juste avant l’église de St-Hippolyte, empruntez le chemin sur la droite juste après la dernière maison pour apercevoir les Grottes de Ferrand.  Sinon, continuez tout droit et tournez à gauche en direction de St Christophe des Bardes.]]></desc></wpt><wpt lat="44.8808474" lon="-0.1197982"><name></name><desc><![CDATA[Juste avant l’église de St-Hippolyte, empruntez le chemin sur la droite juste après la dernière maison pour apercevoir les Grottes de Ferrand.  Sinon, continuez tout droit et tournez à gauche en direction de St Christophe des Bardes.]]></desc></wpt><wpt lat="44.8800112" lon="-0.1202917"><name></name><desc><![CDATA[Face à la maison après l’église, prenez à gauche vers St-Christophe. Au niveau du Ch. Destieux, continuez tout droit jusqu’au stop au Ch. Boutisse.]]></desc></wpt><wpt lat="44.8825731" lon="-0.1111293"><name></name><desc><![CDATA[Face à la maison après l’église, prenez à gauche vers St-Christophe. Au niveau du Ch. Destieux, continuez tout droit jusqu’au stop au Ch. Boutisse.]]></desc></wpt><wpt lat="44.8883579" lon="-0.1053894"><name></name><desc><![CDATA[Au stop, engagez-vous sur la D243 à droite. Continuez tout droit et suivez la direction de St Genès de Castllion et Ch. Valandraud.]]></desc></wpt><wpt lat="44.8884415" lon="-0.0960767"><name></name><desc><![CDATA[Descendez jusqu’à la route de St-Etienne et montez en face vers St-Genès et le Ch. Haut-Veyrac.]]></desc></wpt><wpt lat="44.8866628" lon="-0.0847685"><name></name><desc><![CDATA[Juste après le Ch. Valandraud (sur la gauche), tournez à droite au niveau de l’arrêt de bus et suivez la direction du Ch. de Pressac.]]></desc></wpt><wpt lat="44.8832117" lon="-0.087204"><name></name><desc><![CDATA[Passez devant le Ch. de Pressac (à droite) et continuez à descendre.]]></desc></wpt><wpt lat="44.8807182" lon="-0.0870538"><name></name><desc><![CDATA[Passez devant le chai moderne du Ch. Faugères et continuez votre descente.]]></desc></wpt><wpt lat="44.8766585" lon="-0.0853479"><name></name><desc><![CDATA[A l’intersection en bas de la descente, tournez à droite et allez jusqu’au cédez-le-passage qui rejoint la D130.]]></desc></wpt><wpt lat="44.8748566" lon="-0.0866139"><name></name><desc><![CDATA[Au cédez-le-passage, tournez à droite sur la D130 en direction du Ch. Haut Rocher et continuez tout droit pour arriver à St-Etienne-de-Lisse.]]></desc></wpt><wpt lat="44.8788632" lon="-0.0937486"><name></name><desc><![CDATA[Passez devant le Ch. La Rose Monturon (à gauche) et l’église de St. Etienne de Lisse (à droite). A la patte-d’oie, au niveau de la croix, maintenez le cap à gauche sur la D245.]]></desc></wpt><wpt lat="44.8779357" lon="-0.1303339"><name></name><desc><![CDATA[Traversez St-Laurent-des-Combes en direction de Saint-Emilion et continuez sur la D245 en passant près du Ch. de Candale (restaurant L’Atelier de Candale).]]></desc></wpt><wpt lat="44.8822842" lon="-0.1516843"><name></name><desc><![CDATA[Passez devant le Ch. Pavie (à droite) et continuez tout droit jusqu’à La Gaffelière.]]></desc></wpt><wpt lat="44.885477" lon="-0.156759"><name></name><desc><![CDATA[Au Ch. La Gaffelière, tournez à droite pour monter vers Saint-Emilion.]]></desc></wpt><wpt lat="44.8908054" lon="-0.1550424"><name></name><desc><![CDATA[Continuez et montez dans la rue Guadet, la rue principale et pavée.]]></desc></wpt><wpt lat="44.8938115" lon="-0.1550746"><name></name><desc><![CDATA[Presque en haut de la rue Guadet, tournez à gauche la rue du Clocher jusqu’à l’Office de Tourisme.]]></desc></wpt><trk><trkseg><trkpt lat="44.89371" lon="-0.15695"></trkpt><trkpt lat="44.89382" lon="-0.15705"></trkpt><trkpt lat="44.89387" lon="-0.1571"></trkpt><trkpt lat="44.89392" lon="-0.15716"></trkpt><trkpt lat="44.89396" lon="-0.15725"></trkpt><trkpt lat="44.89402" lon="-0.1574"></trkpt><trkpt lat="44.89429" lon="-0.15719"></trkpt><trkpt lat="44.89452" lon="-0.15702"></trkpt><trkpt lat="44.89479" lon="-0.15679"></trkpt><trkpt lat="44.89499" lon="-0.1566"></trkpt><trkpt lat="44.89541" lon="-0.15622"></trkpt><trkpt lat="44.89565" lon="-0.15597"></trkpt><trkpt lat="44.89577" lon="-0.15582"></trkpt><trkpt lat="44.89583" lon="-0.15575"></trkpt><trkpt lat="44.89587" lon="-0.15566"></trkpt><trkpt lat="44.89589" lon="-0.15562"></trkpt><trkpt lat="44.89586" lon="-0.15556"></trkpt><trkpt lat="44.89586" lon="-0.15552"></trkpt><trkpt lat="44.89588" lon="-0.15546"></trkpt><trkpt lat="44.8959" lon="-0.15542"></trkpt><trkpt lat="44.89594" lon="-0.1554"></trkpt><trkpt lat="44.89596" lon="-0.15532"></trkpt><trkpt lat="44.89597" lon="-0.15524"></trkpt><trkpt lat="44.89598" lon="-0.15514"></trkpt><trkpt lat="44.89597" lon="-0.15504"></trkpt><trkpt lat="44.89595" lon="-0.15475"></trkpt><trkpt lat="44.89597" lon="-0.15463"></trkpt><trkpt lat="44.896" lon="-0.15445"></trkpt><trkpt lat="44.89605" lon="-0.15426"></trkpt><trkpt lat="44.89612" lon="-0.15407"></trkpt><trkpt lat="44.89676" lon="-0.15268"></trkpt><trkpt lat="44.89675" lon="-0.15244"></trk